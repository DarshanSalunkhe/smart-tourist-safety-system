# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# ── Session & JWT ─────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string
JWT_SECRET=change-this-to-a-64-char-random-string

# ── Google OAuth (REQUIRED for server to start) ──────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# ── Frontend URL (for OAuth redirects) ───────────────────────────────────────
FRONTEND_URL=http://localhost:5500

# ── CORS: comma-separated list of allowed frontend origins ────────────────────
ALLOWED_ORIGINS=http://localhost:5500

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Frontend API base URL (used by Vite) ──────────────────────────────────────
VITE_API_URL=http://localhost:5000

# ── Gemini AI (optional — leave blank to use rule-based fallback only) ────────
GEMINI_API_KEY=

# ── SMS SOS (optional — leave blank to use mock/console mode) ─────────────────
# Provider: fast2sms | twilio | mock (default)
SMS_PROVIDER=mock
SMS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
